{
  "name": "@tex/desktop",
  "private": true,
  "version": "0.0.1",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "bun run --parallel dev:bundle dev:electron",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "build": "tsdown",
    "dist": "electron-builder --config electron-builder.config.mjs",
    "start": "bun run scripts/start-electron.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tex/session-node": "workspace:*",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@tex/contracts": "workspace:*",
    "@types/node": "^22.15.3",
    "electron": "40.6.0",
    "electron-builder": "^26.0.12",
    "tsdown": "^0.20.3",
    "typescript": "5.9.2"
  },
  "productName": "Tex"
}
