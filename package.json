{
  "name": "@tex/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=@tex/web --filter=@tex/desktop",
    "dev:web": "turbo run dev --filter=@tex/web",
    "dev:desktop": "turbo run dev --filter=@tex/web --filter=@tex/desktop",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@tex/web --filter=@tex/desktop",
    "start": "turbo run start --filter=@tex/desktop",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist .turbo"
  },
  "devDependencies": {
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "tsdown": "^0.20.3",
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "vitest": "^4.0.8"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=20"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
