{
  "name": "@tex/contracts",
  "private": true,
  "version": "0.0.1",
  "files": ["dist"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsdown src/index.ts --format esm,cjs --dts --watch --clean",
    "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tex/editor": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "^0.20.3",
    "typescript": "5.9.2"
  }
}
